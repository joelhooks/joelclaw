# Flagg Central shadow runtime env.
# Copy to .env on Flagg and replace placeholder values. Never commit .env.

COMPOSE_PROJECT_NAME=joelclaw-central-shadow
CENTRAL_MACHINE_ID=mac-studio-central
CENTRAL_HOSTNAME=flagg
CENTRAL_BIND_ADDR=127.0.0.1
# Keep 0 for shadow local-disk smoke. Set to 1 only after NAS mounts are installed/proven.
CENTRAL_REQUIRE_NAS=0

SERVICE_USER=joelclaw
SERVICE_GROUP=staff
SERVICE_ROOT=/Users/Shared/joelclaw
CENTRAL_REPO_ROOT=/Users/Shared/joelclaw/src/joelclaw

CENTRAL_REDIS_DATA=/Users/Shared/joelclaw/services/redis
CENTRAL_TYPESENSE_DATA=/Users/Shared/joelclaw/services/typesense
CENTRAL_INNGEST_DATA=/Users/Shared/joelclaw/services/inngest
# Restate needs Unix sockets under /restate-data; macOS/Colima bind mounts reject those.
# Use a Docker named volume inside the Colima VM instead of a /Users/Shared bind mount.
CENTRAL_RESTATE_VOLUME=joelclaw-central-restate-data

# NAS tiering for ADR-0246 Gate 5. MinIO should become an S3 facade over these NAS tiers,
# not a local Flagg SSD object store. Install/prove mounts before enabling CENTRAL_REQUIRE_NAS.
NAS_HOST=three-body
NAS_IP=192.168.1.163
NAS_EXPECTED_INTERFACE=en0
NAS_EXPECTED_MEDIA=10Gbase-T
# ADR-0088 target is 9000, but the 2026-05-30 Flagg proof uses 1500 because jumbo frames blackholed to three-body.
NAS_EXPECTED_MTU=1500
# Conservative proof options. Decide before cutover whether soft mounts are acceptable for final MinIO-on-NFS durability.
NAS_NFS_OPTIONS=rw,resvport,nfsvers=3,tcp,soft,intr,timeo=10,retrans=2,rsize=8192,wsize=8192,dsize=8192
CENTRAL_NAS_NVME_EXPORT=three-body:/volume2/data
CENTRAL_NAS_NVME_MOUNT=/Volumes/nas-nvme
CENTRAL_NAS_HDD_EXPORT=three-body:/volume1/joelclaw
CENTRAL_NAS_HDD_MOUNT=/Volumes/three-body
CENTRAL_MINIO_HOT_DATA=/Volumes/nas-nvme/s3
CENTRAL_MINIO_COLD_DATA=/Volumes/three-body/s3
# Shadow-only default. Gate 5 target MinIO data must be NAS-backed, not local Flagg SSD.
# For one hot MinIO surface after proof, set CENTRAL_MINIO_DATA=${CENTRAL_MINIO_HOT_DATA}.
# If both tiers need S3, add explicit hot/cold MinIO surfaces instead of mixing tiers in one data root.
CENTRAL_MINIO_DATA=/Users/Shared/joelclaw/services/minio
CENTRAL_BACKUP_DIR=/Users/Shared/joelclaw/backups/central
CENTRAL_LOG_DIR=/Users/Shared/joelclaw/logs/central

# Rhizomatic/Chorus Network Memory canary. Keep loopback; clients on other machines use private SSH tunnels.
CHORUS_HTTP_HOST=127.0.0.1
CHORUS_HTTP_PORT=4821
CHORUS_STORE=/Users/Shared/joelclaw/services/rhizomatic/chorus-memory.jsonl
CHORUS_HTTP_TOKEN=replace-with-flagg-rhizomatic-token
CHORUS_MASTER_SEED=replace-with-64-hex-char-master-seed
CHORUS_RHIZOMATIC_SECRET_ENV_FILE=/Users/Shared/joelclaw/secrets/chorus-rhizomatic.env
RHIZOMATIC_UPSTREAM_ROOT=/Users/Shared/joelclaw/upstream/rhizomatic

# Shadow-only credentials. Replace before running. Do not reuse Panda production secrets unless a migration step explicitly says so.
# Inngest self-hosted event/signing keys must be valid even-length hex strings.
TYPESENSE_API_KEY=replace-with-flagg-shadow-typesense-key
MINIO_ROOT_USER=replace-with-flagg-shadow-minio-user
MINIO_ROOT_PASSWORD=replace-with-flagg-shadow-minio-password
INNGEST_EVENT_KEY=replace-with-even-length-hex-event-key
INNGEST_SIGNING_KEY=replace-with-even-length-hex-signing-key

# Colima profile for the shadow substrate. Keep separate from dev/default profiles.
COLIMA_PROFILE=joelclaw-central
COLIMA_CPU=8
COLIMA_MEMORY=24
COLIMA_DISK=200
