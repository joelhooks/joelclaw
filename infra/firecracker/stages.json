      "node --version succeeds inside microVM",
      "git --version succeeds inside microVM",
      "pi --version succeeds inside microVM"
    ],
    "files": [
      "infra/firecracker/Dockerfile.rootfs",
      "infra/firecracker/build-rootfs.sh",
      "infra/firecracker/kernel/"
    ],
    "artifacts": ["rootfs.ext4", "vmlinux"],
    "tool": "codex"
  },
  {
    "id": "create-snapshot",
    "name": "Create warm snapshot",
    "executionMode": "sandbox",
    "dependsOn": ["build-rootfs"],
    "phase": "B",
    "acceptance": [
