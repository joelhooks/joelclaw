      "Queue drainer consuming events",
      "launchd com.joel.restate-worker disabled"
    ],
    "files": [
      "k8s/restate-worker.yaml",
      "k8s/publish-restate-worker.sh",
      "packages/restate/Dockerfile"
    ],
    "artifacts": ["Dockerfile", "k8s manifest", "publish script"],
    "tool": "codex"
  },
  {
    "id": "install-firecracker",
    "name": "Enable nested virt in Colima + install Firecracker",
    "executionMode": "sandbox",
    "phase": "B",
    "acceptance": [
      "firecracker --version works inside Colima VM",
