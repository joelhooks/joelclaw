[
  {
    "id": "fix-admin-port",
    "name": "Fix Restate admin reachability",
    "executionMode": "manual",
    "phase": "A",
    "acceptance": [
      "joelclaw jobs status reports restate as healthy without manual port-forward",
      "NodePort 30970 added to k8s/restate.yaml Service for admin API (9070)"
    ],
    "files": ["k8s/restate.yaml"],
    "notes": "5-minute fix. One line in the Service spec."
  },
  {
    "id": "triage-queue",
    "name": "Triage stale queue",
    "executionMode": "manual",
    "phase": "A",
    "acceptance": [
      "Queue depth < 10",
      "No items older than 1 hour",
      "Unhandled event families documented"
    ],
    "notes": "Inspect 58 items, ack/drain dead webhook events."
  },
  {
    "id": "worker-to-k8s",
    "name": "Move Restate worker into k8s",
    "executionMode": "codex",
    "dependsOn": ["fix-admin-port"],
    "phase": "A",
    "acceptance": [
      "kubectl get pods -n joelclaw | grep restate-worker shows 1/1 Running",
