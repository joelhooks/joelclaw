<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.joel.headless-bootstrap</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/joel/Code/joelhooks/joelclaw/infra/headless-bootstrap.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TARGET_USER</key>
        <string>joel</string>
        <key>TARGET_HOME</key>
        <string>/Users/joel</string>
        <key>REPO_ROOT</key>
        <string>/Users/joel/Code/joelhooks/joelclaw</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/Users/joel/.local/bin:/Users/joel/.bun/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/joel/.local/log/headless-bootstrap.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/joel/.local/log/headless-bootstrap.err</string>
</dict>
</plist>
