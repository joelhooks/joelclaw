# Copy to clickhouse-password-hashes.env on three-body and chmod 0600.
# Values are lowercase SHA-256 hex digests of 48-character plaintext secrets
# restricted to [A-Za-z0-9_-]. Never commit the populated file.
CLICKHOUSE_DEFAULT_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
CLICKHOUSE_MESSAGE_JOURNAL_MIGRATION_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
CLICKHOUSE_MESSAGE_JOURNAL_WRITER_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
CLICKHOUSE_MESSAGE_JOURNAL_READER_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
CLICKHOUSE_OTEL_RUNTIME_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
CLICKHOUSE_OTEL_READER_PASSWORD_SHA256=REPLACE_WITH_64_HEX_CHARS
