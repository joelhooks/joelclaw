# Operator-only migration environment. Copy outside the repo, chmod 0600,
# populate with a 48-character [A-Za-z0-9_-] secret at apply time, export
# for the migration command, then unset.
MESSAGE_JOURNAL_CLICKHOUSE_URL=http://127.0.0.1:18123
MESSAGE_JOURNAL_DATABASE=joelclaw_private
MESSAGE_JOURNAL_TABLE=message_journal_events
MESSAGE_JOURNAL_ADMIN_USER=message_journal_migration
MESSAGE_JOURNAL_ADMIN_PASSWORD=REPLACE_WITH_JOURNAL_MIGRATION_PASSWORD
