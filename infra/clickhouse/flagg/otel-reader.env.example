# Optional operator shell environment for direct ClickHouse query commands that
# do not use the capability TOML yet, including `joelclaw usage` and
# `joelclaw video trace`. Copy outside the repo, chmod 0600, and source only
# for the command that needs it. Use the 48-character [A-Za-z0-9_-] password
# format from the runbook.
CLICKHOUSE_URL=http://127.0.0.1:18123
CLICKHOUSE_QUERY_URL=http://127.0.0.1:18123
CLICKHOUSE_DATABASE=joelclaw
CLICKHOUSE_OTEL_TABLE=otel_events
CLICKHOUSE_USER=otel_reader
CLICKHOUSE_PASSWORD=REPLACE_WITH_OTEL_READER_PASSWORD
