# Operator-only journal query environment. Copy outside the repo, chmod 0600,
# and populate with a 48-character [A-Za-z0-9_-] secret at apply time. Do not
# give this identity to the gateway worker.
MESSAGE_JOURNAL_CLICKHOUSE_URL=http://127.0.0.1:18123
MESSAGE_JOURNAL_DATABASE=joelclaw_private
MESSAGE_JOURNAL_TABLE=message_journal_events
MESSAGE_JOURNAL_READER_USER=message_journal_reader
MESSAGE_JOURNAL_READER_PASSWORD=REPLACE_WITH_JOURNAL_READER_PASSWORD
