# Merge these keys into ~/.config/system-bus.env on Flagg.
# Keep that file mode 0600. Replace placeholders with 48-character secrets
# restricted to [A-Za-z0-9_-] at apply time.
# The system-bus process gets the table-scoped OTEL runtime identity because it
# writes events, checks schema, and runs the daily usage report.
OTEL_STORE=clickhouse
CLICKHOUSE_URL=http://127.0.0.1:18123
CLICKHOUSE_DATABASE=joelclaw
CLICKHOUSE_OTEL_TABLE=otel_events
CLICKHOUSE_USER=otel_runtime
CLICKHOUSE_PASSWORD=REPLACE_WITH_OTEL_RUNTIME_PASSWORD
OTEL_CLICKHOUSE_TTL_DAYS=180

MESSAGE_JOURNAL_CLICKHOUSE_URL=http://127.0.0.1:18123
MESSAGE_JOURNAL_DATABASE=joelclaw_private
MESSAGE_JOURNAL_TABLE=message_journal_events
MESSAGE_JOURNAL_WRITER_USER=message_journal_writer
MESSAGE_JOURNAL_WRITER_PASSWORD=REPLACE_WITH_JOURNAL_WRITER_PASSWORD
