{
  "name": "@joelclaw/world-restate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vercel Workflow DevKit World interface backed by Restate",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "package.json",
    "README.md"
  ]
}